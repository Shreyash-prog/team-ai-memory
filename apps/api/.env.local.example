# Local dev environment for the API workspace.
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
#
# Used by Drizzle Kit (drizzle.config.ts) for local `db:generate` / `db:migrate`
# / `db:studio` runs. In production, the Worker reads DATABASE_URL from a
# Wrangler secret (`wrangler secret put DATABASE_URL`), not from this file.

# Neon Postgres connection string (pooled or direct; use the connection string
# from your Neon project dashboard). Must include `?sslmode=require`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
